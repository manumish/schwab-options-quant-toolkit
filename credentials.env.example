# Schwab API Credentials
# Copy this file to ~/.schwab/credentials.env and fill in your values
# NEVER commit this file to git!

# From Schwab Developer Portal (developer.schwab.com)
# Dashboard > Your App > View Details
SCHWAB_CLIENT_ID=your_client_id_here
SCHWAB_CLIENT_SECRET=your_client_secret_here

# Must match exactly what you configured in your Schwab app
SCHWAB_CALLBACK_URL=https://developer.schwab.com/oauth2-redirect.html
